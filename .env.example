# Frontend Environment Variables
# Copy this file to .env.local and update the values

# Admin Authentication (Frontend Fallback)
# Used when backend is unavailable (e.g., GitHub Pages deployment)
VITE_ADMIN_EMAIL=admin@aseer.health.sa
VITE_ADMIN_PASSWORD=change-me-to-a-secure-password

# Backend Environment Variables (server/.env)
# These should be different from frontend and stored securely

# Admin Authentication (Backend)
# ADMIN_EMAIL=admin@aseer.health.sa
# ADMIN_PASSWORD=change-me-to-a-secure-password
# JWT_SECRET=change-me-to-a-random-secure-string
# NODE_ENV=production
